<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:bal="http://wixtoolset.org/schemas/v4/wxs/bal">
  <Bundle
    Name="FenSight"
    Manufacturer="FenSight"
    Version="$(var.ProductVersion)"
    UpgradeCode="{8C4A1C9A-1FD6-4A3C-8E6F-CB0C0E9A0E56}"
    IconSourceFile="$(var.SourceRepoRoot)\favicon.ico">

    <BootstrapperApplication>
      <bal:WixStandardBootstrapperApplication
        Theme="rtfLicense"
        ThemeFile="Assets\FenSightTheme.xml"
        LocalizationFile="Assets\FenSightTheme.wxl"
        LicenseFile="FenSightLicense.rtf"
        LogoFile="Assets\FenSightLogo.png"
        LaunchTarget="[ProgramFilesFolder]FenSight\FenSightApp.exe"
        SuppressOptionsUI="no" />
    </BootstrapperApplication>

    <!-- Drives the "Create a desktop shortcut" checkbox on the install screen (default on). -->
    <Variable Name="CreateDesktopShortcut" Value="1" Type="numeric" bal:Overridable="yes" />
    <!-- Uninstall cleanup is always opt-in. Keeping all three at zero preserves upgrades,
         repairs, and the default uninstall/reinstall experience. -->
    <Variable Name="PurgeFenSightAppData" Value="0" Type="numeric" bal:Overridable="yes" />
    <Variable Name="PurgeFenSightCache" Value="0" Type="numeric" bal:Overridable="yes" />
    <Variable Name="PurgeFenSightTemp" Value="0" Type="numeric" bal:Overridable="yes" />

    <Chain>
      <!-- Keep the embedded MSI out of Installed Apps when setup.exe owns the
           install. The separately downloadable MSI remains usable and visible. -->
      <MsiPackage SourceFile="$(var.MsiPath)" Vital="yes" Visible="no">
        <MsiProperty Name="INSTALLDESKTOPSHORTCUT" Value="[CreateDesktopShortcut]" />
        <MsiProperty Name="PURGEFENSIGHTAPPDATA" Value="[PurgeFenSightAppData]" />
        <MsiProperty Name="PURGEFENSIGHTCACHE" Value="[PurgeFenSightCache]" />
        <MsiProperty Name="PURGEFENSIGHTTEMP" Value="[PurgeFenSightTemp]" />
      </MsiPackage>
    </Chain>
  </Bundle>
</Wix>
